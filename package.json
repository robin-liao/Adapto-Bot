{
  "name": "adapto-bot",
  "version": "1.0.0",
  "description": "Robin's bot for Microsoft Teams platform",
  "main": "dist/server.js",
  "scripts": {
    "prettier": "prettier \"./src/**/*.ts\" \"./src/**/*.tsx\" --write",
    "start": "npm run server",
    "script": "nodemon --exec node --inspect=2266 -r ts-node/register",
    "dev": "npm run build:dev",
    "build": "npm run clean & webpack --config ./build-scripts/webpack.prod.js",
    "clean": "rimraf dist & rimraf public/js",
    "build:dev": "npm run clean & NODE_ENV=development webpack --config ./build-scripts/webpack.dev.js --watch",
    "server": "NODE_ENV=production node dist/server.js",
    "server:dev": "npm run exec dist/server.js"
  },
  "author": "Robin Liao",
  "license": "ISC",
  "dependencies": {
    "@azure/data-tables": "^13.3.2",
    "@opentelemetry/api": "^1.9.0",
