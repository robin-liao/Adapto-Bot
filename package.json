    "@googleapis/customsearch": "^3.2.0",
    "@googleapis/youtube": "^22.0.0",
    "@googlemaps/google-maps-services-js": "^3.4.0",
    "adaptive-expressions": "^4.19.3",
    "adaptivecards": "^2.10.0-beta1",
    "adaptivecards-templating": "^2.3.1",
    "axios": "^1.3.4",
    "body-parser": "^1.19.0",
    "botbuilder": "^4.23.0",
    "cheerio": "^1.0.0",
    "cookie-parser": "^1.4.5",
    "cors": "^2.8.5",
    "dotenv": "^6.2.0",
    "express": "^5.0.0-alpha.8",
    "fast-xml-parser": "^5.2.5",
    "ffmpeg-static": "^5.2.0",
    "fluent-ffmpeg": "^2.1.3",
    "google-auth-library": "^9.15.1",
    "lodash": "^4.17.19",
    "markdown-it": "^14.1.0",
    "markdown-it-collapsible": "^1.0.0",
    "nodemon": "^3.1.14",
    "openai": "^4.86.1",
    "parse-curl-js": "^1.0.3",
    "redis": "^3.1.2",
    "string-template": "^1.0.0",
    "ts-node": "^7.0.1",
    "uuid": "^11.1.0",
    "wav": "^1.0.2",
